{
  "name": "zappy-assistant",
  "private": true,
  "version": "1.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap:dev": "node scripts/bootstrap.mjs dev",
    "bootstrap:prod": "node scripts/bootstrap.mjs prod",
    "bootstrap:debug": "node scripts/bootstrap.mjs debug",
    "start:dev": "node scripts/start.mjs dev",
    "start:dev:resolvers": "node scripts/start.mjs dev --with-external-services",
    "stop:dev": "node scripts/stop.mjs dev",
    "start:prod": "node scripts/start.mjs prod",
    "stop:prod": "node scripts/stop.mjs prod",
    "start:debug": "node scripts/start.mjs debug",
    "stop:debug": "node scripts/stop.mjs debug",
    "restart:dev": "node scripts/restart.mjs dev",
    "restart:dev:resolvers": "node scripts/restart.mjs dev --with-external-services",
    "restart:prod": "node scripts/restart.mjs prod",
    "restart:debug": "node scripts/restart.mjs debug",
    "pm2:check-infra": "node scripts/check-infra.mjs",
    "pm2:start:dev": "node scripts/check-infra.mjs && pm2 start ecosystem.config.cjs",
    "pm2:start:prod": "node scripts/check-infra.mjs && pm2 start ecosystem.prod.config.cjs",
    "pm2:stop": "pm2 stop all",
    "pm2:delete": "pm2 delete all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload all",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "dev": "concurrently -k -n admin-api,media-resolver-api,wa-gateway,worker,admin-ui \"npm run dev -w @zappy/admin-api\" \"npm run dev -w @zappy/media-resolver-api\" \"npm run dev -w @zappy/wa-gateway\" \"npm run dev -w @zappy/worker\" \"npm run dev -w @zappy/admin-ui\"",
    "build": "npm run prisma:generate && npm run build -w @zappy/shared && npm run build -w @zappy/core && npm run build -w @zappy/ai && npm run build -w @zappy/adapters && npm run build -w @zappy/admin-ui && npm run build -w @zappy/admin-api && npm run build -w @zappy/assistant-api && npm run build -w @zappy/media-resolver-api && npm run build -w @zappy/wa-gateway && npm run build -w @zappy/worker",
    "lint": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "docker:up": "docker compose -f infra/docker-compose.yml up --build -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "typecheck": "tsc --noEmit -p tsconfig.base.json"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "cfonts": "^3.3.0",
    "concurrently": "^9.1.2",
    "pm2": "^6.0.14",
    "prisma": "^6.4.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  }
}
