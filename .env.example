NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zappy_assistant?schema=public
REDIS_URL=redis://localhost:6379
ADMIN_API_PORT=3333
ADMIN_UI_PORT=8080
ADMIN_API_TOKEN=change-me
WA_GATEWAY_INTERNAL_PORT=3334
WA_GATEWAY_INTERNAL_BASE_URL=http://localhost:3334
WA_GATEWAY_INTERNAL_TOKEN=change-me-internal
MEDIA_RESOLVER_API_PORT=3335
MEDIA_RESOLVER_API_BASE_URL=http://localhost:3335
MEDIA_RESOLVER_API_TOKEN=change-me-media-resolver
MEDIA_RESOLVER_JOB_TTL_SECONDS=900
MEDIA_RESOLVER_CLEANUP_INTERVAL_MS=30000
MEDIA_RESOLVER_TEMP_DIR=.tmp/media-resolver
MEDIA_RESOLVER_TEMP_RETENTION_SECONDS=900
QUEUE_NAME=reminders
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MODEL=gpt-4o-mini
LLM_ENABLED=true
LLM_MEMORY_MESSAGES=10
LLM_PERSONA=secretary_default
BOT_TIMEZONE=America/Cuiaba
BOT_PREFIX=/
LOG_FORMAT=pretty
LOG_LEVEL=debug
LOG_PRETTY_MODE=dev
LOG_COLORIZE=true
LOG_VERBOSE_FIELDS=true
WA_REACTIONS_ENABLED=true
WA_REACTION_PROGRESS=⏱️
WA_REACTION_SUCCESS=✅
WA_REACTION_FAILURE=❌
INBOUND_MAX_MESSAGE_AGE_SECONDS=30
INBOUND_STARTUP_WATERMARK_TOLERANCE_SECONDS=5
INBOUND_MISSING_TIMESTAMP_STARTUP_GRACE_SECONDS=15
INBOUND_MESSAGE_CLAIM_TTL_SECONDS=172800
STICKER_MAX_VIDEO_SECONDS=10
AUDIO_CAPABILITY_ENABLED=true
AUDIO_AUTO_TRANSCRIBE_ENABLED=true
AUDIO_STT_MODEL=gpt-4o-mini-transcribe
AUDIO_STT_TIMEOUT_MS=25000
AUDIO_MAX_DURATION_SECONDS=180
AUDIO_MAX_BYTES=8388608
AUDIO_STT_LANGUAGE=
AUDIO_COMMAND_DISPATCH_ENABLED=true
AUDIO_COMMAND_ALLOWLIST=help,ping,agenda,status,task,note,reminder,timer,calc,sticker,toimg,rnfig,tts,search,google,search-ai,sai,img,gimage,imglink,dl
AUDIO_COMMAND_MIN_CONFIDENCE=0.8
AUDIO_TRANSCRIPT_PREVIEW_CHARS=120
TTS_ENABLED=true
TTS_MODEL=gpt-4o-mini-tts
TTS_TIMEOUT_MS=25000
TTS_AUDIO_FORMAT=opus
TTS_TRANSLATION_MODEL=gpt-4o-mini
TTS_TRANSLATION_TIMEOUT_MS=20000
TTS_DEFAULT_SOURCE_LANGUAGE=pt-BR
TTS_DEFAULT_LANGUAGE=pt-BR
TTS_DEFAULT_VOICE=female
TTS_MALE_VOICE=alloy
TTS_FEMALE_VOICE=nova
TTS_MAX_TEXT_CHARS=700
TTS_SEND_AS_PTT=true
SEARCH_ENABLED=true
SEARCH_PROVIDER=google
SEARCH_MAX_RESULTS=3
SEARCH_TIMEOUT_MS=10000
SEARCH_AI_ENABLED=true
SEARCH_AI_PROVIDER=openai
SEARCH_AI_MODEL=gpt-4.1-mini
SEARCH_AI_TIMEOUT_MS=25000
SEARCH_AI_MAX_SOURCES=4
GEMINI_API_KEY=
GEMINI_SEARCH_AI_MODEL=gemini-2.5-flash
GEMINI_SEARCH_GROUNDING_ENABLED=true
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
# Compat legado (equivalente ao GOOGLE_SEARCH_ENGINE_ID):
GOOGLE_SEARCH_CX=
OPENVERSE_API_BASE_URL=https://api.openverse.org/v1/images/
PIXABAY_API_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
IMAGE_SEARCH_ENABLED=true
IMAGE_SEARCH_PROVIDER=native
IMAGE_SEARCH_MAX_RESULTS=3
IMAGE_SEARCH_MEDIA_NORMALIZE_ENABLED=true
IMAGE_SEARCH_MEDIA_NORMALIZE_MAX_DIMENSION=2048
IMAGE_SEARCH_MEDIA_NORMALIZE_JPEG_QUALITY=86
IMAGE_SEARCH_MEDIA_NORMALIZE_TRIGGER_BYTES=2097152
DOWNLOADS_MODULE_ENABLED=true
DOWNLOADS_MAX_BYTES=16777216
DOWNLOADS_PROVIDER_YT_ENABLED=true
DOWNLOADS_PROVIDER_IG_ENABLED=true
DOWNLOADS_PROVIDER_FB_ENABLED=true
DOWNLOADS_PROVIDER_DIRECT_ENABLED=true
DOWNLOADS_DIRECT_TIMEOUT_MS=12000
# Bridge to internal auxiliary youtube-resolver wrapper
# Local helper start: npm run start:dev -- --with-external-services
YT_RESOLVER_ENABLED=false
YT_RESOLVER_BASE_URL=http://localhost:3401
YT_RESOLVER_TOKEN=
YT_RESOLVER_TIMEOUT_MS=20000
YT_RESOLVER_MAX_BYTES=16777216
# Bridge to internal auxiliary facebook-resolver wrapper
# Local helper start: npm run start:dev -- --with-external-services
FB_RESOLVER_ENABLED=false
FB_RESOLVER_BASE_URL=http://localhost:3402
FB_RESOLVER_TOKEN=
FB_RESOLVER_TIMEOUT_MS=20000
FB_RESOLVER_MAX_BYTES=16777216
YOUTUBE_API_KEY=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v23.0
WA_SESSION_PATH=.wa_auth
ONLY_GROUP_ID=
DEFAULT_TENANT_NAME=Default Tenant
DEFAULT_BOT_NAME=Zappy
ASSISTANT_MODE_DEFAULT=professional
FUN_MODE_DEFAULT=off
CONSENT_TERMS_VERSION=2026-03
CONSENT_LINK=https://services.net.br/politicas
CONSENT_SOURCE=wa-gateway
