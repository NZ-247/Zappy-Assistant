generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Scope {
  GLOBAL
  TENANT
  GROUP
  USER
}

enum MatchType {
  CONTAINS
  REGEX
  STARTS_WITH
}

enum TaskStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELED
}

enum TimerStatus {
  SCHEDULED
  FIRED
  FAILED
  CANCELED
}

enum ConsentStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ChatMode {
  ON
  OFF
}

enum FunMode {
  ON
  OFF
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PROCESS
}

enum MemoryRole {
  system
  user
  assistant
  tool
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Tenant {
  id            String         @id @default(uuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  groups        Group[]
  users         User[]
  userConsents  UserConsent[]
  conversations Conversation[]
  featureFlags  FeatureFlag[]
  triggers      Trigger[]
  tasks         Task[]
  reminders     Reminder[]
  prompts       Prompt[]
  notes         Note[]
  timers        Timer[]
  botAdmins     BotAdmin[]

  @@index([name])
}

model Group {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  waGroupId     String         @unique
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  reminders     Reminder[]
  featureFlags  FeatureFlag[]
  triggers      Trigger[]
  tasks         Task[]
  notes         Note[]
  timers        Timer[]
  prompts       Prompt[]
  chatMode      ChatMode      @default(ON)
  isOpen        Boolean       @default(true)
  welcomeEnabled Boolean      @default(false)
  welcomeText   String?
  fixedMessageText String?
  rulesText     String?
  funMode       FunMode?
  moderationConfig Json?      @default("{}")
  allowed       Boolean       @default(false)
  botIsAdmin    Boolean       @default(false)
  botAdminCheckedAt DateTime?

  @@index([tenantId])
}

model User {
  id                 String        @id @default(uuid())
  tenantId           String
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  displayName        String?
  waUserId           String        @unique
  phoneNumber        String?       @unique
  lidJid             String?       @unique
  pnJid              String?       @unique
  aliases            String[]      @default([])
  role               String        @default("member")
  permissionRole     String?
  relationshipProfile String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  consents           UserConsent[]
  messages           Message[]
  reminders          Reminder[]
  featureFlags       FeatureFlag[]
  triggers           Trigger[]
  tasks              Task[]
  notes              Note[]
  timers             Timer[]
  botAdminEntries    BotAdmin[]

  @@index([tenantId])
}

model Conversation {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  subject     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  messages    Message[]
  memories    ConversationMemory[]

  @@index([tenantId])
  @@index([groupId])
  @@unique([tenantId, groupId])
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId       String
  body           String
  direction      MessageDirection @default(INBOUND)
  waMessageId    String?
  waUserId       String?
  waGroupId      String?
  rawJson        Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@index([userId])
  @@index([tenantId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String
  description String?
  enabled     Boolean  @default(true)
  value       String   @default("on")
  scope       Scope    @default(GLOBAL)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope])
  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
}

model Trigger {
  id               String    @id @default(uuid())
  name             String
  pattern          String
  responseTemplate String
  matchType        MatchType @default(CONTAINS)
  enabled          Boolean   @default(true)
  priority         Int       @default(0)
  cooldownSeconds  Int       @default(0)
  scope            Scope     @default(GLOBAL)
  tenantId         String?
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  groupId          String?
  group            Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
  @@index([scope])
  @@index([groupId])
  @@index([userId])
}

model Task {
  id        String     @id @default(uuid())
  tenantId  String?
  tenant    Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  groupId   String?
  group     Group?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  waUserId  String?
  waGroupId String?
  type      String
  payload   Json
  status    TaskStatus @default(PENDING)
  runAt     DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, runAt])
  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
}

model Reminder {
  id            String         @id @default(uuid())
  tenantId      String?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  waUserId      String?
  waGroupId     String?
  message       String
  remindAt      DateTime
  status        ReminderStatus @default(SCHEDULED)
  sentMessageId String?
  createdAt     DateTime       @default(now())

  @@index([remindAt])
  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
}

model Note {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  waUserId  String?
  waGroupId String?
  scope     Scope
  text      String
  sequence  Int
  publicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
  @@unique([tenantId, publicId])
  @@unique([tenantId, scope, groupId, userId, sequence])
}

model Timer {
  id            String       @id @default(uuid())
  tenantId      String?
  tenant        Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  groupId       String?
  group         Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  waUserId      String?
  waGroupId     String?
  fireAt        DateTime
  durationMs    Int
  label         String?
  status        TimerStatus  @default(SCHEDULED)
  sentMessageId String?
  createdAt     DateTime     @default(now())

  @@index([fireAt])
  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
}

model Prompt {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([groupId])
}

model ConversationMemory {
  id             String     @id @default(uuid())
  tenantId       String
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  waUserId       String?
  role           MemoryRole
  content        String
  metadataJson   Json?
  createdAt      DateTime   @default(now())

  @@index([conversationId, createdAt])
  @@index([tenantId, createdAt])
}

model BotAdmin {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  waUserId  String
  createdAt DateTime @default(now())

  @@unique([tenantId, waUserId])
  @@index([tenantId])
  @@index([userId])
}

model UserConsent {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        ConsentStatus  @default(PENDING)
  termsVersion  String
  acceptedAt    DateTime?
  declinedAt    DateTime?
  source        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@unique([tenantId, userId, termsVersion])
}

model AuditLog {
  id        String      @id @default(uuid())
  actor     String
  action    AuditAction
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
